# Django
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/chetopia
POSTGRES_DB=chetopia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_USER_KEY=
REDIS_ACCOUNT_KEY=

# LLM Provider (ollama or groq)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava-phi3:3.8b

# Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Groq (optional, used when LLM_PROVIDER=groq)
GROQ_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=

# TTS Provider (kokoro or edge-tts)
TTS_PROVIDER=kokoro
KOKORO_API_URL=

# RAG
SIMILARITY_THRESHOLD=0.45
TOP_K=5
